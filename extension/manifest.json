{
  "manifest_version": 3,
  "name": "ReFlip",
  "version": "1.0.1",
  "description": "Turn your Depop shop or Vinted closet into copy/paste-ready drafts for the other site. One click. No login, no automation.",
  "icons": { "128": "icon128.png" },
  "action": {
    "default_title": "Cross-list this shop / closet",
    "default_icon": { "128": "icon128.png" }
  },
  "permissions": ["scripting"],
  "host_permissions": [
    "https://www.depop.com/*",
    "https://www.vinted.com/*"
  ],
  "background": { "service_worker": "background.js" }
}
